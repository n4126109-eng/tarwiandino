<style>

:root{
--primary:#0f5132;
--secondary:#198754;
--accent:#d4af37;
--light:#f5f9f6;
--dark:#1e293b;
--white:#ffffff;
--shadow:0 10px 30px rgba(0,0,0,.12);
}

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:'Poppins',sans-serif;
background:var(--light);
color:#333;
overflow-x:hidden;
}

header{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.55)),
url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1800&q=80');
background-size:cover;
background-position:center;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
color:white;
}

.hero{
max-width:1000px;
}

.hero h1{
font-size:5rem;
font-weight:800;
letter-spacing:2px;
margin-bottom:20px;
}

.hero p{
font-size:1.3rem;
line-height:1.8;
margin-bottom:35px;
}

.btn{
display:inline-block;
padding:15px 35px;
background:var(--accent);
color:black;
font-weight:700;
text-decoration:none;
border-radius:50px;
transition:.3s;
}

.btn:hover{
transform:translateY(-3px);
}

nav{
position:sticky;
top:0;
z-index:999;
background:white;
box-shadow:0 2px 10px rgba(0,0,0,.1);
}

nav ul{
display:flex;
justify-content:center;
list-style:none;
flex-wrap:wrap;
}

nav ul li{
margin:15px;
}

nav ul li a{
text-decoration:none;
color:var(--primary);
font-weight:600;
}

section{
padding:90px 8%;
}

.section-title{
text-align:center;
margin-bottom:60px;
}

.section-title h2{
font-size:2.8rem;
color:var(--primary);
margin-bottom:10px;
}

.section-title p{
color:#666;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:25px;
}

.card{
background:white;
padding:30px;
border-radius:20px;
box-shadow:var(--shadow);
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.stat{
background:white;
padding:35px;
text-align:center;
border-radius:20px;
box-shadow:var(--shadow);
}

.stat h3{
font-size:3rem;
color:var(--secondary);
}

.highlight{
color:var(--accent);
font-weight:700;
}

.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
align-items:center;
}

.about img{
width:100%;
border-radius:20px;
box-shadow:var(--shadow);
}

table{
width:100%;
border-collapse:collapse;
background:white;
box-shadow:var(--shadow);
border-radius:15px;
overflow:hidden;
}

table th{
background:var(--primary);
color:white;
padding:15px;
}

table td{
padding:15px;
border-bottom:1px solid #ddd;
}

.timeline{
position:relative;
max-width:1000px;
margin:auto;
}

.timeline::after{
content:'';
position:absolute;
width:6px;
background:var(--secondary);
top:0;
bottom:0;
left:50%;
margin-left:-3px;
}

.step{
padding:20px 40px;
position:relative;
width:50%;
}

.step.left{
left:0;
}

.step.right{
left:50%;
}

.step-content{
background:white;
padding:25px;
border-radius:15px;
box-shadow:var(--shadow);
}

footer{
background:var(--dark);
color:white;
text-align:center;
padding:40px;
}

@media(max-width:768px){

.hero h1{
font-size:3rem;
}

.about{
grid-template-columns:1fr;
}

.timeline::after{
left:20px;
}

.step{
width:100%;
padding-left:60px;
padding-right:20px;
}

.step.right{
left:0;
}
}

</style>
</head>

